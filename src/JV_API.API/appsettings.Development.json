{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=JV_API_Dev;Integrated Security=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information"
      }
    }
  },
  "Hangfire": {
    "Enabled": true
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200", "http://localhost:3000" ]
  },
  "RateLimiting": {
    "PermitLimit": 1000,
    "WindowSeconds": 60
  }
}
