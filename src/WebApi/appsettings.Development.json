{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=WebApi_Dev;Integrated Security=True;TrustServerCertificate=True;MultipleActiveResultSets=True"
  },
  "Jwt": {
    "SecretKey": "ThisIsADevelopmentSecretKeyForLocalOnly123456789!",
    "Issuer": "WebApi",
    "Audience": "WebApi"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200", "http://localhost:3000" ]
  },
  "LogCleanup": {
    "RetentionDays": 7,
    "RunIntervalHours": 24
  },
  "RateLimiting": {
    "PermitLimit": 1000,
    "WindowSeconds": 60
  },
  "Swagger": {
    "AllowSwaggerUi": true
  }
}
